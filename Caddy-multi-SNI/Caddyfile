{
	storage file_system /caddyserver # 自定义 Caddy 数据存储路径
	admin off # 禁用 admin API
	persist_config off
	log {
		output file /caddyserver/log/error.log # 错误日志目录
		format console
		level ERROR
	}
	log log0 {
		output file /caddyserver/log/access.log # 访问日志目录
		format console
		include http.log.access.log0
	}

	email your@email.com # 修改为自己的电子邮箱，用于 ACME 申请证书

	servers :443 {
		protocols h2 h3 # 在可能需要时自行添加 h1 协议支持
	}
}

# 共用配置，启用 TLS、访问日志与 HSTS
(common) {
	tls {
		protocols tls1.2 tls1.3
	}
	log log0 # 启用访问日志
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload" # 启用 HSTS
	}
}

# Caddy 自动按 SNI 申请并出示对应证书、终结 TLS，再按域名分流到不同后端
a.example.com { # 修改为自己的域名
	import common
	reverse_proxy 127.0.0.1:12345 # 反向代理到后端 A
}

b.example.com { # 修改为自己的域名
	import common
	reverse_proxy 127.0.0.1:23456 # 反向代理到后端 B
}

# 同一证书/站点下还可按路径等进一步分流
c.example.com { # 修改为自己的域名
	import common
	handle /api/* {
		reverse_proxy 127.0.0.1:34567 # /api/* 转发到后端 C-API
	}
	handle {
		reverse_proxy 127.0.0.1:45678 # 其余请求转发到后端 C-Web
	}
}
